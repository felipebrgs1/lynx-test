{
  "name": "lynx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rspeedy build",
    "dev": "rspeedy dev",
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "preview": "rspeedy preview",
    "test": "vitest run",
    "android:reverse": "adb reverse tcp:3000 tcp:3000",
    "android:reverse:list": "adb reverse --list",
    "android:emulator": "emulator -avd Small_Phone",
    "android:open": "adb shell am start -n com.lynx.explorer/.LynxViewShellActivity --es url 'http://localhost:3000/main.lynx.bundle?fullscreen=true'",
    "android:open:emulator": "adb shell am start -n com.lynx.explorer/.LynxViewShellActivity --es url 'http://10.0.2.2:3000/main.lynx.bundle?fullscreen=true'"
  },
  "dependencies": {
    "@lynx-js/react": "^0.116.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@lynx-js/preact-devtools": "^5.0.1",
    "@lynx-js/qrcode-rsbuild-plugin": "^0.4.5",
    "@lynx-js/react-rsbuild-plugin": "^0.12.8",
    "@lynx-js/rspeedy": "^0.13.4",
    "@lynx-js/types": "3.7.0",
    "@rsbuild/plugin-type-check": "1.3.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/react": "^18.3.28",
    "jsdom": "^27.4.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
